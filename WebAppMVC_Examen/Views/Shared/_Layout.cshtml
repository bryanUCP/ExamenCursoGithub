<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - Portal Universitario</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>

<body>

    <!-- HEADER -->
    <header style="background:#006341;color:white">
        <div class="container d-flex align-items-center py-3">
            <img src="https://upload.wikimedia.org/wikipedia/commons/3/3f/Logo_UV.png"
                 style="height:60px;margin-right:15px">

            <div>
                <h4 class="m-0">Portal Académico</h4>
                <small>Sistema de Gestión Universitaria</small>
            </div>
        </div>
    </header>


    <!-- MENU -->
    <nav class="navbar navbar-expand-lg navbar-dark" style="background:#004a2f">
        <div class="container">
            <a class="navbar-brand" href="/">Inicio</a>

            <button class="navbar-toggler" data-bs-toggle="collapse"
                    data-bs-target="#menu">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="menu">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="#">Estudiantes</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="#">Cursos</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="#">Exámenes</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="#">Contacto</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>


    <!-- CONTENIDO -->
    <div class="container mt-4">
        @RenderBody()
    </div>


    <!-- FOOTER -->
    <footer class="text-center mt-5 p-3"
            style="background:#006341;color:white">

        © 2026 Portal Universitario  
        <br>
        Sistema académico institucional

    </footer>

<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>